# ── Database (SQLite - không cần cài gì thêm) ──
DATABASE_URL="file:./dev.db"

# ── JWT ──
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=12h

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Upload ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── Timezone ──
TZ=Asia/Ho_Chi_Minh
