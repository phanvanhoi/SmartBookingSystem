# ── Database (SQLite - không cần cài gì thêm) ──
DATABASE_URL="file:./dev.db"

# ── JWT ──
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=12h

# ── CORS ──
# Comma-separated list of allowed origins. Empty = block cross-origin.
# Example: CORS_ORIGINS=http://localhost:5173,https://musicbox.example.com
CORS_ORIGINS=http://localhost:5173

# Number of proxy hops in front of the app (nginx, cloudflare, docker).
# Required for express-rate-limit to see the real client IP. Default 1.
TRUST_PROXY_HOPS=1

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Upload ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── Facebook integration (optional) ──
# FB_APP_SECRET — used to verify webhook HMAC signature (REQUIRED for FB webhook)
# FB_VERIFY_TOKEN — any random string used during webhook setup with Meta
FB_APP_SECRET=
FB_VERIFY_TOKEN=

# ── Timezone ──
TZ=Asia/Ho_Chi_Minh
