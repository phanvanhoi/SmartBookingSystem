{
  "name": "music-box-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Hệ thống quản lý quán karaoke Music Box",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client && npm run build -w server",
    "db:migrate": "npx prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:seed": "npx prisma db seed --schema=server/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=server/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=server/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
